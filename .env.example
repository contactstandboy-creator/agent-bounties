# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://agent_bounties:agent_bounties_secret@localhost:5432/agent_bounties"

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL="redis://:redis_secret@localhost:6379"

# ─── AI Providers ────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."

# ─── Search ──────────────────────────────────────────────────
# Get from https://api.search.brave.com
BRAVE_SEARCH_API_KEY="BSA..."

# ─── Pump.fun GO ─────────────────────────────────────────────
PUMPFUN_GO_BASE_URL="https://go.pump.fun"
PUMPFUN_GO_API_URL="https://api.go.pump.fun"

# ─── Agent Config ────────────────────────────────────────────
# Minimum expected value in USD to attempt a bounty
MIN_EV_THRESHOLD="2.0"
# Minimum classification confidence to attempt a bounty
MIN_CONFIDENCE_THRESHOLD="0.70"
# Target approval rate (used for calibration)
TARGET_APPROVAL_RATE="0.80"

# ─── Indexer ─────────────────────────────────────────────────
# How often to poll Pump.fun GO for new bounties (seconds)
INDEXER_POLL_INTERVAL="60"

# ─── App ─────────────────────────────────────────────────────
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"
ADMIN_SECRET="admin-secret-token"

# ─── Environment ─────────────────────────────────────────────
NODE_ENV="development"
LOG_LEVEL="debug"
